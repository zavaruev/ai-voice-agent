# ============================================================
# .gitignore for ai-voice-agent orchestrator repository
# ============================================================

# ---------------------------------------------------------------------------
# Private secrets — never commit these
# ---------------------------------------------------------------------------
secrets.h
device_map.json
config.json
config_backup*.json
*.env
.env.*

# ---------------------------------------------------------------------------
# Firmware binaries and version files
# ---------------------------------------------------------------------------
*.bin
*.bin.version

# ---------------------------------------------------------------------------
# ESP-IDF build artifacts
# ---------------------------------------------------------------------------
build/
sdkconfig
sdkconfig.breadboard
sdkconfig.freenove
sdkconfig.old
managed_components/
dependencies.lock
.cache/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/

# ---------------------------------------------------------------------------
# Backups and archives
# ---------------------------------------------------------------------------
project_backup*.tar.gz
*.tar.gz
*.zip

# ---------------------------------------------------------------------------
# Logs and temp files
# ---------------------------------------------------------------------------
verify_log.txt
*.log
*.tmp
*.bak
*_tmp

# ---------------------------------------------------------------------------
# OS and editor
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
esp-idf-5.5.2/
